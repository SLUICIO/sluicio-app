# Copy to sluicio.env and fill in. Pass with --env-file sluicio.env.
# Do NOT commit the filled-in copy (sluicio.env is gitignored).

# Registry the Sluicio images are pulled from. The official public images are
# at ghcr.io/sluicio; pin TAG to a version for a release, or leave `latest`.
# (This env file + docker-compose.registry.yml is the all-in-one setup: it also
# starts a bundled Postgres + ClickHouse. To use your own databases instead,
# see sluicio.env.external.example + docker-compose.registry.external-db.yml.)
REGISTRY=ghcr.io
NAMESPACE=sluicio
TAG=latest

# Postgres (control-plane DB). Pick strong values on first install.
POSTGRES_USER=sluicio
POSTGRES_PASSWORD=change-me-postgres

# ClickHouse (telemetry store).
CLICKHOUSE_USER=sluicio
CLICKHOUSE_PASSWORD=change-me-clickhouse

# Public origin users reach Sluicio at (e.g. https://sluicio.acme.com).
# Notifications sent in the background — alert pages and unacknowledged-error
# notifications — embed a deep link built from this. Leave empty and those
# links are simply omitted. (In-browser password-reset links fall back to the
# request's Origin, so this matters mainly for the notifiers.)
SLUICIO_APP_URL=

# Published host ports. Defaults shown. To run MULTIPLE instances on one
# host, give each its own env file with distinct ports here AND start it
# under its own compose project name (-p), e.g.:
#   docker compose -p sluicio-acme --env-file acme.env -f docker-compose.registry.yml up -d
# The project name namespaces the containers, network, and the
# postgres_data / clickhouse_data volumes, so instances stay isolated.
FRONTEND_PORT=8080       # browser / reverse proxy → UI (+ /api proxy)
CELL_API_PORT=8081       # reverse proxy → cell-api /api/*
CELL_INGEST_PORT=4318    # OTLP/HTTP producers → cell-ingest

# Env for running against YOUR OWN external Postgres + ClickHouse.
# Copy to sluicio.env and fill in. Pass with --env-file sluicio.env.
# Use with docker-compose.registry.external-db.yml (see that file's header).
# Do NOT commit the filled-in copy (sluicio.env is gitignored).

# Registry the Sluicio images are pulled from. The official public images are
# at ghcr.io/sluicio; pin TAG to a version for a release, or leave `latest`.
REGISTRY=ghcr.io
NAMESPACE=sluicio
TAG=latest

# ── Your external Postgres (control-plane DB) ────────────────────────────────
# A single DSN. cell-api applies its migrations here on startup; the database
# ("controlplane" below, but any name works) just needs to exist and be
# reachable with a role that can create tables. Use sslmode=require for a
# managed DB.
POSTGRES_DSN=postgres://user:pass@your-pg-host:5432/controlplane?sslmode=require

# ── Your external ClickHouse (telemetry store) ───────────────────────────────
# Native protocol endpoint (host:9000, or :9440 for TLS). cell-api creates its
# tables in CLICKHOUSE_DATABASE on startup.
CLICKHOUSE_ENDPOINT=your-ch-host:9000
CLICKHOUSE_DATABASE=telemetry
CLICKHOUSE_USERNAME=sluicio
CLICKHOUSE_PASSWORD=change-me-clickhouse

# ── If you only have ONE of the two ──────────────────────────────────────────
# Layer a bundled overlay and set that DB's user/password instead of the
# external vars above. See docker-compose.bundled-postgres.yml /
# docker-compose.bundled-clickhouse.yml. For a bundled Postgres overlay set:
#   POSTGRES_USER=sluicio
#   POSTGRES_PASSWORD=change-me-postgres
# For a bundled ClickHouse overlay set:
#   CLICKHOUSE_USER=sluicio
#   CLICKHOUSE_PASSWORD=change-me-clickhouse

# Public origin users reach Sluicio at (e.g. https://sluicio.acme.com). Used to
# build deep links in background notifications; empty = links omitted.
SLUICIO_APP_URL=

# Published host ports (defaults shown).
FRONTEND_PORT=8080       # browser / reverse proxy → UI (+ /api proxy)
CELL_API_PORT=8081       # reverse proxy → cell-api /api/*
CELL_INGEST_PORT=4318    # OTLP/HTTP producers → cell-ingest
